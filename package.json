{
  "name": "agent-team",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-agnostic agent team orchestration",
  "repository": {
    "type": "git",
    "url": "https://github.com/nsheaps/agent-team.git"
  },
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "lib/*",
    "plugins"
  ],
  "nx": {
    "name": "root",
    "includedScripts": [
      "format",
      "lint"
    ]
  },
  "scripts": {
    "format": "prettier --write \"**/*.md\" --ignore-path .prettierignore --ignore-path .prettierignore-root && bash scripts/lint-shell.sh",
    "lint": "prettier --check \"**/*.md\" --ignore-path .prettierignore --ignore-path .prettierignore-root && bash scripts/lint-shell.sh"
  },
  "devDependencies": {
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/bun": "^1.1.0",
    "nx": "^22.0.0",
    "prettier": "^3.0.0",
    "release-it": "^20.0.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
