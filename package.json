{
  "name": "agent-team",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-agnostic agent team orchestration",
  "repository": {
    "type": "git",
    "url": "https://github.com/nsheaps/agent-team.git"
  },
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "services/*",
    "lib/*"
  ],
  "nx": {
    "name": "root",
    "includedScripts": [
      "format",
      "format-check",
      "lint",
      "lint-check"
    ]
  },
  "scripts": {
    "format": "prettier --write \"**/*.md\" --ignore-path .prettierignore --ignore-path .prettierignore-root",
    "format-check": "prettier --check \"**/*.md\" --ignore-path .prettierignore --ignore-path .prettierignore-root",
    "lint": "bun run format-check && bash scripts/lint-shell.sh",
    "lint-check": "bun run format-check && bash scripts/lint-shell.sh"
  },
  "devDependencies": {
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.0",
    "@types/bun": "^1.1.0",
    "nx": "^20.0.0",
    "prettier": "^3.0.0",
    "release-it": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
