{
  "name": "@nsheaps/agents-pg-utils",
  "version": "0.0.0",
  "description": "Postgres utilities for the agent-team monorepo.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nsheaps/agent-team.git",
    "directory": "lib/agents-pg-utils"
  },
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write . --ignore-path ../../.prettierignore && tsc --noEmit",
    "lint": "prettier --check . --ignore-path ../../.prettierignore && tsc --noEmit",
    "build": "tsc -b",
    "test": "bun test --pass-with-no-tests"
  }
}
