{
  "description": "Maps every Claude Code hook event to one renderer (hook-stream.sh) that prints the hook name + params/response to the user only. Verbosity configurable via plugins.settings.yaml (hook-utils.verbosity: quiet|normal|full).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-stream.sh",
            "timeout": 5
          }
        ]
      }
    ],
