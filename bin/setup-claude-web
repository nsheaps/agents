#!/usr/bin/env bash
# setup-claude-web — curl-able bootstrap for Claude Code on the web.
#
# Resolves a layered `agent.yaml` config from an UPSTREAM agent repo and
# applies it to the current Claude Code environment, so a brand-new repo's
# web session can "initialize as if it were running from the Jack repo" —
# inheriting that agent's plugins, marketplaces, plugin config, and
# settings WITHOUT committing any of it into the new repo.
#
# INTENDED USE — in the web environment's "Setup script" field (the env
# preconfigures the 1Password service-account token), paste:
#
#   curl -fsSL https://raw.githubusercontent.com/nsheaps/agents/main/bin/setup-claude-web | bash -s -- nsheaps/.ai-agent-jack
#
# (or set CLAUDE_WEB_UPSTREAM instead of the positional arg). The setup
# script runs as root BEFORE Claude Code launches and its filesystem
# (incl. ~/.claude) is snapshot-cached, so installing plugins here warms
# the cache: the first session already has them, and the plugins' own
# SessionStart hooks (1pass installs op + injects secrets, github-app
# mints a token, mise installs tools) run normally.
#
# CONFIG MODEL — agent.yaml is layered via `extends`:
#   base agent config (nsheaps/agents)   — what any agent needs
#     ^ extended by org config (nsheaps/.org)  — org specifics
#       ^ extended by the role/agent repo (e.g. nsheaps/.ai-agent-jack)
# Each layer declares only its delta; they are deep-merged base -> leaf.
# See docs/runbooks/setup-claude-code-web.md for the schema.
#
# WRITE TARGET — web (CLAUDE_CODE_REMOTE set): ~/.claude/settings.json.
# Otherwise: ~/.claude/settings.local.json (your real settings.json is
# left untouched). plugins.settings.yaml -> ~/.claude/plugins.settings.yaml
# in both. Nothing is hardcoded — the plugin/marketplace/setting choices
# all come from the upstream agent.yaml chain.
set -euo pipefail

UPSTREAM="${1:-${CLAUDE_WEB_UPSTREAM:-}}"
if [ -z "$UPSTREAM" ]; then
  cat >&2 <<'USAGE'
[setup-claude-web] ERROR: no upstream agent config given.
  usage: setup-claude-web <owner/repo[:path][@ref]>   (or a local path)
  e.g.:  curl -fsSL .../bin/setup-claude-web | bash -s -- nsheaps/.ai-agent-jack
         CLAUDE_WEB_UPSTREAM=nsheaps/.ai-agent-jack bash setup-claude-web
USAGE
  exit 2
fi
export CLAUDE_WEB_UPSTREAM="$UPSTREAM"

log() { printf '[setup-claude-web] %s\n' "$*"; }

# --- Ensure interpreter + YAML support ---------------------------------
if ! command -v python3 >/dev/null 2>&1; then
  log "ERROR: python3 is required but not on PATH" >&2
  exit 1
fi
if ! python3 -c 'import yaml' 2>/dev/null; then
  log "PyYAML not found — attempting install"
  python3 -m pip install --quiet --disable-pip-version-check pyyaml \
    || { command -v apt-get >/dev/null 2>&1 && apt-get install -y -q python3-yaml; } \
    || { log "ERROR: PyYAML required and could not be installed" >&2; exit 1; }
fi

# Hand off to the Python resolver/applier. Inputs come from the
# environment (CLAUDE_WEB_UPSTREAM, CLAUDE_CODE_REMOTE, CLAUDE_CONFIG_DIR,
# HOME); the heredoc is single-quoted so bash performs no expansion inside.
exec python3 - <<'PYEOF'
import json
import os
import shutil
import subprocess
import sys
import tempfile

import yaml

MAX_DEPTH = 16


def log(msg):
    print(f"[setup-claude-web] {msg}", flush=True)


def warn(msg):
    print(f"[setup-claude-web] WARNING: {msg}", file=sys.stderr, flush=True)


# --- upstream ref resolution -------------------------------------------
_clone_cache = {}


def _looks_local(ref):
    return ref.startswith(("/", "./", "../", "~")) or os.path.exists(
        os.path.expanduser(ref)
    )


def _parse_remote(ref):
    """owner/repo[:path][@gitref] -> (owner_repo, path, gitref)."""
    gitref = None
    if "@" in ref:
        ref, gitref = ref.rsplit("@", 1)
    path = "agent.yaml"
    if ":" in ref:
        ref, path = ref.split(":", 1)
    return ref, path, gitref


def _clone(owner_repo, gitref):
    key = (owner_repo, gitref)
    if key in _clone_cache:
        return _clone_cache[key]
    dest = tempfile.mkdtemp(prefix="agent-cfg-")
    url = owner_repo if "://" in owner_repo else f"https://github.com/{owner_repo}"
    cmd = ["git", "clone", "--depth", "1", "--quiet"]
    if gitref:
        cmd += ["--branch", gitref]
    cmd += [url, dest]
    subprocess.run(cmd, check=True)
    _clone_cache[key] = dest
    return dest


def load_config(ref):
    """Return the parsed agent.yaml dict for a ref (local path or remote)."""
    if _looks_local(ref):
        p = os.path.expanduser(ref)
        if os.path.isdir(p):
            p = os.path.join(p, "agent.yaml")
        with open(p) as fh:
            return yaml.safe_load(fh) or {}
    owner_repo, path, gitref = _parse_remote(ref)
    root = _clone(owner_repo, gitref)
    with open(os.path.join(root, path)) as fh:
        return yaml.safe_load(fh) or {}


def resolve_chain(start):
    """Walk `extends` from leaf to base; return configs base-first."""
    chain, seen, ref, depth = [], set(), start, 0
    while ref:
        if ref in seen:
            raise SystemExit(f"extends cycle detected at {ref}")
        if depth > MAX_DEPTH:
            raise SystemExit("extends chain too deep")
        seen.add(ref)
        cfg = load_config(ref)
        chain.append((ref, cfg))
        ref = cfg.get("extends")
        depth += 1
    chain.reverse()  # base first so the leaf wins on merge
    return chain


# --- merge --------------------------------------------------------------
def deep_merge(a, b):
    if isinstance(a, dict) and isinstance(b, dict):
        out = dict(a)
        for k, v in b.items():
            out[k] = deep_merge(a[k], v) if k in a else v
        return out
    if isinstance(a, list) and isinstance(b, list):
        out = list(a)  # union, preserve order, dedupe
        for x in b:
            if x not in out:
                out.append(x)
        return out
    return b  # scalars / type mismatch: child (b) wins


def merge_chain(chain):
    merged = {}
    for _ref, cfg in chain:
        merged = deep_merge(merged, cfg)
    return merged


# --- translate merged config into settings shapes ----------------------
def marketplace_entry(value):
    """Normalize a marketplace value into an extraKnownMarketplaces entry."""
    if isinstance(value, str):
        return {"source": {"source": "github", "repo": value}}
    if isinstance(value, dict):
        if isinstance(value.get("source"), dict):
            return value  # already a full {source: {...}} entry
        return {"source": value}  # shorthand {source: github, repo: ...}
    raise SystemExit(f"unsupported marketplace value: {value!r}")


def marketplace_add_target(entry):
    """The arg for `claude plugin marketplace add` (repo or directory path)."""
    src = entry["source"]
    return src.get("repo") or src.get("path")


# --- settings file I/O --------------------------------------------------
def read_json(path):
    if os.path.isfile(path):
        with open(path) as fh:
            return json.load(fh) or {}
    return {}


def write_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + ".tmp"
    with open(tmp, "w") as fh:
        json.dump(data, fh, indent=2)
        fh.write("\n")
    os.replace(tmp, path)


def read_yaml(path):
    if os.path.isfile(path):
        with open(path) as fh:
            return yaml.safe_load(fh) or {}
    return {}


def write_yaml(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + ".tmp"
    with open(tmp, "w") as fh:
        yaml.safe_dump(data, fh, sort_keys=False, default_flow_style=False)
    os.replace(tmp, path)


# --- cache warming via the claude CLI ----------------------------------
def warm_cache(marketplaces, plugins, web):
    if os.environ.get("CLAUDE_WEB_SKIP_INSTALL"):
        log("CLAUDE_WEB_SKIP_INSTALL set — skipping plugin install / cache warm")
        return
    if not shutil.which("claude"):
        warn("claude CLI not on PATH — skipping cache warm (config still written)")
        return
    # web: --scope user writes ~/.claude/settings.json (== our target).
    # else: --scope local from a throwaway cwd warms the shared cache
    #       without touching the user's real settings.json.
    scope = "user" if web else "local"
    cwd = None if web else tempfile.mkdtemp(prefix="agent-cfg-warm-")
    for name, entry in marketplaces.items():
        target = marketplace_add_target(entry)
        if not target:
            continue
        log(f"marketplace add {name} ({target}) [scope={scope}]")
        if subprocess.run(
            ["claude", "plugin", "marketplace", "add", target, "--scope", scope],
            cwd=cwd,
        ).returncode != 0:
            warn(f"marketplace add failed for {target} (non-fatal)")
    for plugin in plugins:
        log(f"plugin install {plugin} [scope={scope}]")
        if subprocess.run(
            ["claude", "plugin", "install", plugin, "--scope", scope], cwd=cwd
        ).returncode != 0:
            warn(f"plugin install failed for {plugin} (non-fatal)")
    if cwd:
        shutil.rmtree(cwd, ignore_errors=True)


# --- main ---------------------------------------------------------------
def main():
    upstream = os.environ["CLAUDE_WEB_UPSTREAM"]
    web = bool(os.environ.get("CLAUDE_CODE_REMOTE"))
    config_dir = os.environ.get("CLAUDE_CONFIG_DIR") or os.path.join(
        os.path.expanduser("~"), ".claude"
    )
    target_name = "settings.json" if web else "settings.local.json"
    target = os.path.join(config_dir, target_name)
    ps_path = os.path.join(config_dir, "plugins.settings.yaml")

    log(f"upstream: {upstream}")
    log(f"environment: {'web (CLAUDE_CODE_REMOTE)' if web else 'local'}")

    chain = resolve_chain(upstream)
    log("config chain (base -> leaf): " + " -> ".join(ref for ref, _ in chain))
    merged = merge_chain(chain)

    marketplaces = {
        name: marketplace_entry(val)
        for name, val in (merged.get("marketplaces") or {}).items()
    }
    plugins = list(merged.get("plugins") or [])
    plugin_settings = merged.get("pluginSettings") or {}
    passthrough = merged.get("settings") or {}

    if merged.get("name"):
        log(f"agent: {merged['name']}")
    log(f"marketplaces: {', '.join(marketplaces) or '(none)'}")
    log(f"plugins: {', '.join(plugins) or '(none)'}")

    # 1. Warm the plugin cache (and, in web, write enabledPlugins to the
    #    target via --scope user) so the first session has them + hooks run.
    warm_cache(marketplaces, plugins, web)

    # 2. Materialize the merged plugin config at user scope so the plugins
    #    read their settings (op:// refs, github-app ref, mise opts, ...).
    if plugin_settings:
        write_yaml(ps_path, deep_merge(read_yaml(ps_path), plugin_settings))
        log(f"wrote {ps_path}")

    # 3. Deep-merge marketplaces + enabledPlugins + settings passthrough
    #    into the target settings file, preserving anything already there.
    additions = {
        "extraKnownMarketplaces": marketplaces,
        "enabledPlugins": {p: True for p in plugins},
    }
    additions = deep_merge(additions, passthrough)
    write_json(target, deep_merge(read_json(target), additions))
    log(f"wrote {target}")
    log("done")


if __name__ == "__main__":
    main()
PYEOF
