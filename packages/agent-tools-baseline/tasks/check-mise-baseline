#!/usr/bin/env bash
set -euo pipefail

# check-mise-baseline — verifies that .config/mise/conf.d/00-agent-baseline.toml
# matches the expected canonical content. Run in CI to catch baseline drift.
#
# In the agents repo: diffs against packages/agent-tools-baseline/agent-baseline.mise.toml.
# In consumer repos (Phase 2+): fetches from pinned raw-GitHub URL and diffs.
#
# Exits 0 on match, 1 with diff output on mismatch.

DEST="${MISE_PROJECT_ROOT}/.config/mise/conf.d/00-agent-baseline.toml"
CANONICAL="${MISE_PROJECT_ROOT}/packages/agent-tools-baseline/agent-baseline.mise.toml"

if [ ! -f "${DEST}" ]; then
  echo "ERROR: ${DEST} not found. Run 'mise run sync-mise-baseline' first." >&2
  exit 1
fi

if [ -f "${CANONICAL}" ]; then
  # agents repo: diff against local canonical source
  if diff -u "${CANONICAL}" "${DEST}"; then
    echo "OK: baseline is up to date."
  else
    echo "" >&2
    echo "ERROR: .config/mise/conf.d/00-agent-baseline.toml has drifted from canonical." >&2
    echo "Run 'mise run sync-mise-baseline' to fix, then commit the updated file." >&2
    exit 1
  fi
else
  # consumer repo: fetch from pinned raw-GitHub URL and diff
  # (exercised in Phase 2 when a git tag is published for the agents repo)
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  VERSION_FILE="${SCRIPT_DIR}/../VERSION"
  if [ ! -f "${VERSION_FILE}" ]; then
    echo "ERROR: VERSION file not found at ${VERSION_FILE}" >&2
    exit 1
  fi
  VERSION=$(cat "${VERSION_FILE}")
  URL="https://raw.githubusercontent.com/nsheaps/agents/v${VERSION}/packages/agent-tools-baseline/agent-baseline.mise.toml"
  TMPFILE=$(mktemp)
  trap 'rm -f "${TMPFILE}"' EXIT
  echo "Fetching canonical baseline v${VERSION} for comparison..."
  curl -fsSL "${URL}" -o "${TMPFILE}"
  if diff -u "${TMPFILE}" "${DEST}"; then
    echo "OK: baseline matches v${VERSION}."
  else
    echo "" >&2
    echo "ERROR: .config/mise/conf.d/00-agent-baseline.toml has drifted from v${VERSION}." >&2
    echo "Run 'mise run sync-mise-baseline' to fix, then commit the updated file." >&2
    exit 1
  fi
fi
