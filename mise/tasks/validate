#!/usr/bin/env bash
#MISE description="Validate plugin structure and marketplace consistency"
set -e

mise run validate-marketplace

VALID=true
FAILED_PLUGINS=()
for plugin_json in plugins/claude-code/*/.claude-plugin/plugin.json; do
  mise run validate-plugin "$plugin_json" || { VALID=false; FAILED_PLUGINS+=("$plugin_json"); }
done

# if the path to the claude binary is in */.local/share/mise/installs/* then mise prune in case it was installed at runtime
if [[ "$(command -v claude)" == *".local/share/mise/installs/"* ]]; then
  echo "Pruning mise installs..."
  mise prune -y
fi

if [ "$VALID" = true ]; then
  echo "All plugins validated successfully!"
else
  echo "Validation failed!"
  echo "Failed plugins:"
  for p in "${FAILED_PLUGINS[@]}"; do
    echo " - $p"
  done
  exit 1
fi
