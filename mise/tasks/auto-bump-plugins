#!/usr/bin/env bash
#MISE description="Auto-bump plugin versions for changed plugins, skipping already-bumped ones. Usage: mise run auto-bump-plugins [--change-base=REF] [--version-base=REF]"
# --change-base: ref for detecting code changes (default: origin/main)
# --version-base: ref for version comparison (default: origin/main)
#
# On PRs, typically: --change-base=origin/<base-branch> --version-base=origin/<base-branch>
# On main, typically: --change-base=last-released --version-base=last-released
#   (the floating release tag; invoked via plugins/release.sh from the nx release target)
# Locally: defaults work (compares to origin/main for both)
set -euo pipefail

# Parse args
CHANGE_BASE="origin/main"
VERSION_BASE="origin/main"
for arg in "$@"; do
  case "$arg" in
    --change-base=*) CHANGE_BASE="${arg#*=}" ;;
    --version-base=*) VERSION_BASE="${arg#*=}" ;;
  esac
done

# Resolve a git ref: try origin/<ref>, then <ref> directly, then HEAD~1
resolve_ref() {
  local ref="$1"
  if git rev-parse --verify "origin/$ref" >/dev/null 2>&1; then
    echo "origin/$ref"
  elif git rev-parse --verify "$ref" >/dev/null 2>&1; then
    echo "$ref"
  else
    echo "HEAD~1"
  fi
}

CHANGE_BASE=$(resolve_ref "$CHANGE_BASE")
VERSION_BASE=$(resolve_ref "$VERSION_BASE")

echo "Change detection base: $CHANGE_BASE" >&2
echo "Version comparison base: $VERSION_BASE" >&2

BUMPED_PLUGINS=()
SKIPPED_PLUGINS=()
BUMP_ENTRIES=()
REPORT_MD="| Plugin | Base | Current | Action |\n|---|---|---|---|"

for plugin_dir in plugins/claude-code/*; do
  [ -d "$plugin_dir" ] || continue
  PLUGIN_NAME=$(basename "$plugin_dir")
  PLUGIN_JSON="$plugin_dir/.claude-plugin/plugin.json"
  [ -f "$PLUGIN_JSON" ] || continue

  # Detect code changes (excluding plugin.json and CHANGELOG.md)
  HAS_CHANGES=false
  if git diff --name-only "$CHANGE_BASE..HEAD" -- "$plugin_dir" 2>/dev/null \
    | grep -v 'CHANGELOG.md$' | grep -v 'plugin.json$' | grep -q .; then
    HAS_CHANGES=true
  fi

  [ "$HAS_CHANGES" = "true" ] || continue

  # Get versions
  BASE_VERSION=$(git show "$VERSION_BASE:$PLUGIN_JSON" 2>/dev/null | jq -r '.version // "0.1.0"' 2>/dev/null || echo "0.1.0")
  HEAD_VERSION=$(jq -r '.version // "0.1.0"' "$PLUGIN_JSON" 2>/dev/null || echo "0.1.0")

  # Skip if already bumped higher than base
  if [ "$HEAD_VERSION" != "$BASE_VERSION" ]; then
    HIGHER=$(printf '%s\n%s' "$HEAD_VERSION" "$BASE_VERSION" | sort -V | tail -1)
    if [ "$HIGHER" = "$HEAD_VERSION" ]; then
      echo "✅ $PLUGIN_NAME: already bumped $BASE_VERSION → $HEAD_VERSION (keeping)" >&2
      SKIPPED_PLUGINS+=("$PLUGIN_NAME")
      REPORT_MD="$REPORT_MD\n| $PLUGIN_NAME | $BASE_VERSION | $HEAD_VERSION | Already bumped |"
      BUMP_ENTRIES+=("$(jq -nc \
        --arg name "$PLUGIN_NAME" --arg path "$PLUGIN_JSON" \
        --arg base "$BASE_VERSION" --arg new "$HEAD_VERSION" --arg action "already-bumped" \
        '{name:$name,path:$path,base:$base,new:$new,action:$action}')")
      continue
    fi
  fi

  # Auto-bump patch version using jq
  NEW_VERSION=$(echo "$HEAD_VERSION" | awk -F. '{print $1"."$2"."$3+1}')
  echo "⬆️  $PLUGIN_NAME: bumping $HEAD_VERSION → $NEW_VERSION" >&2

  jq --arg v "$NEW_VERSION" '.version = $v' "$PLUGIN_JSON" > /tmp/plugin-bump-tmp.json
  mv /tmp/plugin-bump-tmp.json "$PLUGIN_JSON"

  BUMPED_PLUGINS+=("$PLUGIN_NAME")
  REPORT_MD="$REPORT_MD\n| $PLUGIN_NAME | $BASE_VERSION | $NEW_VERSION | Auto-bumped |"
  BUMP_ENTRIES+=("$(jq -nc \
    --arg name "$PLUGIN_NAME" --arg path "$PLUGIN_JSON" \
    --arg base "$BASE_VERSION" --arg new "$NEW_VERSION" --arg action "auto-bumped" \
    '{name:$name,path:$path,base:$base,new:$new,action:$action}')")
done

# Output JSON result
HAS_BUMPS="false"
if [ ${#BUMPED_PLUGINS[@]} -gt 0 ]; then
  HAS_BUMPS="true"
fi

# Combine per-plugin entries (auto-bumped + already-bumped) into a JSON array.
if [ ${#BUMP_ENTRIES[@]} -gt 0 ]; then
  BUMPS_JSON=$(printf '%s\n' "${BUMP_ENTRIES[@]}" | jq -sc '.')
else
  BUMPS_JSON='[]'
fi

jq -n \
  --argjson has_bumps "$HAS_BUMPS" \
  --arg bumped "${BUMPED_PLUGINS[*]:-}" \
  --arg skipped "${SKIPPED_PLUGINS[*]:-}" \
  --arg report_md "$(printf '%b' "$REPORT_MD")" \
  --argjson bumps "$BUMPS_JSON" \
  '{
    has_bumps: $has_bumps,
    bumped: $bumped,
    skipped: $skipped,
    report_md: $report_md,
    bumps: $bumps
  }'
